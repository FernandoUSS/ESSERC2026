\newlabel{sec:BTI}{{IV}{3}{}{}{}}
\newlabel{fig:OTF_MSM_time}{{3a}{4}{}{}{}}
\newlabel{sub@fig:OTF_MSM_time}{{(a)}{a}}
\newlabel{fig:BTI_IdVg}{{3b}{4}{}{}{}}
\newlabel{sub@fig:BTI_IdVg}{{(b)}{b}}
\newlabel{fig:OTF_differentVstr}{{3c}{4}{}{}{}}
\newlabel{sub@fig:OTF_differentVstr}{{(c)}{c}}
\newlabel{fig:MSM_duts}{{3d}{4}{}{}{}}
\newlabel{sub@fig:MSM_duts}{{(d)}{d}}
\newlabel{fig:MSM_comparison}{{3e}{4}{}{}{}}
\newlabel{sub@fig:MSM_comparison}{{(e)}{e}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces (a)~\textbf  {BTI experiments}: Each point corresponds to the $V_\mathsf  {th}$ extracted from an $I_\mathsf  {D}$--$V_\mathsf  {G}$ at the corresponding time. The device state is only assessed during relaxation in MSM measurements, whereas in OTF measurements, it is continuously monitored. ~(b)~\textbf  {Stress and Relaxation $I_\mathsf  {D}$--$V_\mathsf  {G}$s}: The degradation manifests mainly as a $V_\mathsf  {th}$ shift. A CC criterion, $I_\mathsf  {th}$, must be defined to extract $V_\mathsf  {th}$. ~(c)~\textbf  {OTF PBTI measurement}: An anomalous behavior (negative $\Delta V_\mathsf  {th}$ in PBTI for n-channel FETs) is observed at lower stress voltages and relatively short times. ~(d)~\textbf  {MSM PBTI measurements}: Relaxation curves after 100 s stress for six different devices, revealing high device-to-device variations. ~(e)~\textbf  {PBTI in encapsulated vs. non-encapsulated devices}: hBN encapsulation slightly improves resilience to PBTI stress, likely associated with the presence of an anomalous component.~(f)~\textbf  {PBTI impact on inverter}: Applying a positive bias shifts the inverter transfer curve toward higher input voltages, increasing the transition point $V_\mathsf  {M}$.}}{4}{}\protected@file@percent }
\@writefile{lof}{\contentsline {subfigure}{\numberline{(a)}{\ignorespaces {\relax \fontsize {9}{10pt}\selectfont FETs F, G}}}{4}{}\protected@file@percent }
